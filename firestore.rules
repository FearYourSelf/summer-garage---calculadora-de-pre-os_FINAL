rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/settings/global).data.staff[request.auth.uid] == 'admin' ||
         request.auth.token.email == "flamingmonkey18@gmail.com");
    }

    function isStaff() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/settings/global).data.staff.keys().hasAny([request.auth.uid]) ||
         request.auth.token.email == "flamingmonkey18@gmail.com");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidMechanicState(data) {
      return data.keys().hasAll(['mechanicName', 'dailyFarm', 'weeklyFarm', 'monthlyFarm', 'financeStatus']) &&
             data.mechanicName is string &&
             data.dailyFarm is number &&
             data.weeklyFarm is number &&
             data.monthlyFarm is number &&
             data.financeStatus in ['PENDENTE', 'EM DIA', 'PAGA'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Mechanics Collection
    match /mechanics/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId) && isValidMechanicState(request.resource.data);
      allow update: if (isOwner(userId) || isStaff()) && isValidMechanicState(request.resource.data);
      allow delete: if isAdmin();
    }

    // Global Settings
    match /settings/global {
      allow read: if true; // Everyone needs to see maintenance/broadcast
      allow write: if isStaff();
    }
  }
}
